{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@castai/ai-sdk",
  "version": "0.0.1",
  "description": "AI SDK tools and React developer components for castAI Casper x402 and MPP payments",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fozagtx/castAI.git",
    "directory": "packages/sdk/js/ai"
  },
  "homepage": "https://github.com/fozagtx/castAI#readme",
  "bugs": {
    "url": "https://github.com/fozagtx/castAI/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/esm/react.d.ts",
        "default": "./dist/esm/react.js"
      },
      "require": {
        "types": "./dist/cjs/react.d.cts",
        "default": "./dist/cjs/react.cjs"
      }
    },
    "./react/headless": {
      "import": {
        "types": "./dist/esm/react/headless.d.ts",
        "default": "./dist/esm/react/headless.js"
      },
      "require": {
        "types": "./dist/cjs/react/headless.d.cts",
        "default": "./dist/cjs/react/headless.cjs"
      }
    },
    "./react/ui": {
      "import": {
        "types": "./dist/esm/react/ui.d.ts",
        "default": "./dist/esm/react/ui.js"
      },
      "require": {
        "types": "./dist/cjs/react/ui.d.cts",
        "default": "./dist/cjs/react/ui.cjs"
      }
    },
    "./adapters/vercel-ai": {
      "import": {
        "types": "./dist/esm/adapters/vercel-ai.d.ts",
        "default": "./dist/esm/adapters/vercel-ai.js"
      },
      "require": {
        "types": "./dist/cjs/adapters/vercel-ai.d.cts",
        "default": "./dist/cjs/adapters/vercel-ai.cjs"
      }
    },
    "./adapters/openai": {
      "import": {
        "types": "./dist/esm/adapters/openai.d.ts",
        "default": "./dist/esm/adapters/openai.js"
      },
      "require": {
        "types": "./dist/cjs/adapters/openai.d.cts",
        "default": "./dist/cjs/adapters/openai.cjs"
      }
    },
    "./adapters/langchain": {
      "import": {
        "types": "./dist/esm/adapters/langchain.d.ts",
        "default": "./dist/esm/adapters/langchain.js"
      },
      "require": {
        "types": "./dist/cjs/adapters/langchain.d.cts",
        "default": "./dist/cjs/adapters/langchain.cjs"
      }
    },
    "./adapters/agentkit": {
      "import": {
        "types": "./dist/esm/adapters/agentkit.d.ts",
        "default": "./dist/esm/adapters/agentkit.js"
      },
      "require": {
        "types": "./dist/cjs/adapters/agentkit.d.cts",
        "default": "./dist/cjs/adapters/agentkit.cjs"
      }
    },
    "./adapters/goat": {
      "import": {
        "types": "./dist/esm/adapters/goat.d.ts",
        "default": "./dist/esm/adapters/goat.js"
      },
      "require": {
        "types": "./dist/cjs/adapters/goat.d.cts",
        "default": "./dist/cjs/adapters/goat.cjs"
      }
    }
  },
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check",
    "lint-staged": "biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@castai/mpp": "workspace:*",
    "@castai/x402": "workspace:*",
    "@x402/core": "2.12.0",
    "@x402/fetch": "2.12.0",
    "ai": "^5.0.0",
    "mppx": "0.6.20",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tsup": "8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
