{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@castaisdk/mpp",
  "version": "0.0.6",
  "description": "Casper CSPR payment method for the Machine Payments Protocol",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fozagtx/castAI.git",
    "directory": "packages/sdk/js/mpp"
  },
  "homepage": "https://github.com/fozagtx/castAI#readme",
  "bugs": {
    "url": "https://github.com/fozagtx/castAI/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/esm/server.d.ts",
        "default": "./dist/esm/server.js"
      },
      "require": {
        "types": "./dist/cjs/server.d.cts",
        "default": "./dist/cjs/server.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/esm/client.d.ts",
        "default": "./dist/esm/client.js"
      },
      "require": {
        "types": "./dist/cjs/client.d.cts",
        "default": "./dist/cjs/client.cjs"
      }
    }
  },
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "casper-js-sdk": ">=5.0.12",
    "typescript": ">=5.5.0",
    "mppx": ">=0.4.8",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.15",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  }
}
