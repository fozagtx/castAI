{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "castai",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js/*",
      "examples/*"
    ],
    "catalog": {
      "@biomejs/biome": "2.4.10",
      "@total-typescript/ts-reset": "0.6.1",
      "@tsconfig/bun": "1.0.10",
      "@tsconfig/node22": "22.0.5",
      "@types/bun": "1.3.12",
      "@types/node": "22.19.15",
      "typescript": "6.0.2",
      "uuid": "13.0.0",
      "vitest": "4.1.4",
      "zod": "4.3.6"
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint-staged": "turbo lint-staged",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && husky || true"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@biomejs/biome": "catalog:",
    "@tsconfig/bun": "catalog:",
    "@tsconfig/node22": "catalog:",
    "husky": "9.1.7",
    "turbo": "2.9.5"
  },
  "dependencies": {
    "casper-js-sdk": "5.0.12",
    "typescript": "catalog:"
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}
